# DevPulse Agent Configuration
# Copy this to .env and fill in your values

# Your DevPulse API URL (change to your deployed URL in production)
DEVPULSE_API_URL=http://localhost:5000/api/metrics

# Agent key — generated when you created your team via POST /api/teams
DEVPULSE_AGENT_KEY=paste-your-agent-key-here

# Your team slug (e.g. "my-startup", "backend-team")
DEVPULSE_TEAM_SLUG=my-team

# Request timeout in seconds
DEVPULSE_TIMEOUT=10
