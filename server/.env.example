# Server
PORT=5000
NODE_ENV=development

# MongoDB — replace with your connection string
MONGO_URI=mongodb://localhost:27017/devpulse

# JWT — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Agent API key — agents use this to authenticate metric POST requests
AGENT_API_KEY=devpulse-agent-key-change-in-production

# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=
